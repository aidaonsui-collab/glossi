# Copy this file to .env.local and fill in the values from your Supabase project.
# Vite exposes any var prefixed with VITE_ to client code, so anon key is fine here.
# Never commit .env.local — it is gitignored.

# Supabase — Settings → API in your Supabase dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
