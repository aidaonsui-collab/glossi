# Copy this file to .env.local and fill in the values from your Supabase project.
# Vite exposes any var prefixed with VITE_ to client code, so anon key is fine here.
# Never commit .env.local — it is gitignored.

# Supabase — Settings → API in your Supabase dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry — sentry.io project DSN (free tier covers 5k errors/mo).
# Leave blank for local dev or forks; error reporting silently no-ops
# when missing. Production deploys should set this in Vercel env vars.
# Optional: VITE_SENTRY_ENVIRONMENT (defaults to MODE),
#           VITE_SENTRY_TRACES_RATE (defaults to 0.1).
VITE_SENTRY_DSN=
